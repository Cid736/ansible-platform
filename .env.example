# -----------------------------------------------------------------------
# Copy this file to .env and fill in ALL values marked CHANGE_ME.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=ansible
# CHANGE_ME: strong random password
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ansible_platform
DATABASE_URL=postgresql://ansible:CHANGE_ME_strong_db_password@db:5432/ansible_platform

# JWT — CHANGE_ME: generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_long_random_jwt_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fernet encryption key for credentials — CHANGE_ME: generate with:
#   docker run --rm python:3.12-slim sh -c \
#     "pip install cryptography -q && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
ENCRYPTION_KEY=CHANGE_ME_fernet_key_here

REDIS_URL=redis://redis:6379/0

ANSIBLE_PROJECTS_DIR=/ansible/projects
ANSIBLE_ARTIFACTS_DIR=/ansible/artifacts

# First superuser — CHANGE_ME: set a strong password (min 16 chars).
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=CHANGE_ME_strong_admin_password

# CORS — comma-separated list of allowed front-end origins.
# Example: CORS_ORIGINS=https://ansible.example.com
CORS_ORIGINS=http://localhost:3000

# Set to True only if you want to allow public self-registration.
ALLOW_REGISTRATION=False
