POSTGRES_USER=ansible
POSTGRES_PASSWORD=ansible
POSTGRES_DB=ansible_platform
DATABASE_URL=postgresql://ansible:ansible@db:5432/ansible_platform

SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Generate with: docker run --rm python:3.12-slim sh -c "pip install cryptography -q && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
ENCRYPTION_KEY=

REDIS_URL=redis://redis:6379/0

ANSIBLE_PROJECTS_DIR=/ansible/projects
ANSIBLE_ARTIFACTS_DIR=/ansible/artifacts

FIRST_SUPERUSER=admin
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123
